#!/usr/bin/env bash

set -euo pipefail

cargo clippy --quiet -- -D warnings
find -name '*.rs' -print0 | xargs -0 cargo fmt -- --quiet --check

find -name '*.md' \
  | xargs dirname \
  | sort -u \
  | xargs -I '{}' sh -c 'cd {} && mdsh --frozen -i *.md' \
  |& grep -Ev "^(Using input=|\[> )" || true
